# =========================================
# EduVesting Backend - Environment Variables
# Salin file ini menjadi .env (local) lalu isi nilainya.
# JANGAN commit file .env yang sudah berisi secret asli.
# =========================================

# --- App ---
APP_NAME=EduVesting API
ENVIRONMENT=local
DEBUG=true

# --- Security ---
# generate dengan: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Database (Supabase Postgres) ---
# Ambil dari Supabase Dashboard > Project Settings > Database > Connection string (URI, mode: Session/Transaction)
DATABASE_URL=postgresql+psycopg2://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# --- Google OAuth ---
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=http://localhost:3000/login/callback

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- External API Keys ---
FINNHUB_API_KEY=CHANGE_ME
COINGECKO_API_KEY=
GROQ_API_KEY=CHANGE_ME
GROQ_MODEL=llama-3.3-70b-versatile

# --- Frontend URL ---
FRONTEND_URL=http://localhost:3000
